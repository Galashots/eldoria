# OS / editor cruft
Thumbs.db
Desktop.ini
.DS_Store

# Node (only if a helper tool ever gets installed; the game itself stays dependency-free)
node_modules/
npm-debug.log*

# Local test/dev scratch output (not part of the game)
.playwright-mcp/
.lighthouseci/
